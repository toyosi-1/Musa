# Flutterwave Proxy Environment Variables
# Copy this file to .env and fill in your actual values

# Your Flutterwave Secret Key (from Flutterwave Dashboard)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# Proxy Secret - used to authenticate requests from your main app
# Generate a strong random string: openssl rand -hex 32
PROXY_SECRET=your_random_secret_key_here

# Server Port (default: 8080)
PORT=8080
