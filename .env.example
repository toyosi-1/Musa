# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional: Firebase Measurement ID (for Google Analytics)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Push Notifications (FCM)
# VAPID key: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key-here

# FCM / Firebase Admin — service account credentials (server-side only, never expose to client)
# Use INDIVIDUAL vars on Netlify (avoids the 4 KB function-env size limit).
# Firebase Console → Project Settings → Service accounts → Generate new private key
#
# FCM_PROJECT_ID    = value of "project_id" field in the downloaded JSON
# FCM_CLIENT_EMAIL  = value of "client_email" field
# FCM_PRIVATE_KEY   = value of "private_key" field (paste the full PEM including headers;
#                     Netlify auto-escapes newlines — the code re-expands them at runtime)
FCM_PROJECT_ID=your-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FCM_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n

# Legacy single-var form — still works for local .env.local but DO NOT use on Netlify
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# App Configuration
NEXT_PUBLIC_APP_URL=https://musa-security.com
NEXT_PUBLIC_APP_NAME=Musa

# Email Configuration (for server-side use only)
SMTP_HOST=mail.hspace.cloud
SMTP_PORT=465
SMTP_USER=toyosiajibola@musa-security.com
SMTP_PASS=your_smtp_password

# Database Configuration (if using Firestore/Realtime DB)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
