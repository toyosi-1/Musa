# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional: Firebase Measurement ID (for Google Analytics)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Push Notifications (FCM)
# VAPID key: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key-here

# FCM v1 HTTP API — service account JSON (server-side only, never expose to client)
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON as a single line (escape quotes if needed)
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-...@....iam.gserviceaccount.com","token_uri":"https://oauth2.googleapis.com/token"}

# App Configuration
NEXT_PUBLIC_APP_URL=https://musa-security.com
NEXT_PUBLIC_APP_NAME=Musa

# Email Configuration (for server-side use only)
SMTP_HOST=mail.hspace.cloud
SMTP_PORT=465
SMTP_USER=toyosiajibola@musa-security.com
SMTP_PASS=your_smtp_password

# Database Configuration (if using Firestore/Realtime DB)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
