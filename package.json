    "@types/node": "^20.19.7",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "autoprefixer": "^10.0.1",
    "dotenv": "^16.5.0",
    "eslint": "^8",
    "eslint-config-next": "^14.0.4",
    "firebase-admin": "^13.4.0",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.6",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-import": "^16.1.1",
