{
  "name": "musa-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postbuild": "next-sitemap",
    "prebuild": "node scripts/generate-icons.js && node scripts/generate-splash-screens.js",
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "netlify-build": "npm install && npm run build",
    "build:mobile": "NEXT_EXPORT=true next build",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "mobile:android": "npm run build:mobile && npx cap sync android && npx cap open android",
    "mobile:ios": "npm run build:mobile && npx cap sync ios && npx cap open ios"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": "9.x"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^3.3.2",
    "@sendgrid/mail": "^8.1.5",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "@tailwindcss/nesting": "0.0.0-insiders.565cd3e",
    "@types/qrcode": "^1.5.5",
    "buffer": "^6.0.3",
    "canvas": "^3.1.2",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "crypto-browserify": "^3.12.1",
    "date-fns": "^4.1.0",
    "firebase": "^11.10.0",
    "html5-qrcode": "^2.3.8",
    "next": "^14.2.35",
    "next-pwa": "^5.6.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "protobufjs": "^7.5.3",
    "qrcode": "^1.5.4",
    "qrcode.react": "^3.1.0",
    "querystring-es3": "^0.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-firebase-hooks": "^5.1.1",
    "react-hook-form": "^7.49.2",
    "resend": "^6.9.3",
    "stream-browserify": "^3.0.0",
