# Firebase Configuration
# Replace the placeholder values with your actual Firebase project details

# Firebase API Key (found in Firebase Console > Project Settings > General > Your Apps)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here

# Firebase Auth Domain (usually your-project-id.firebaseapp.com)
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

# Firebase Project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Firebase Database URL (usually https://your-project-id.firebaseio.com or https://your-project-id-default-rtdb.firebaseio.com)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# Firebase Storage Bucket (usually your-project-id.appspot.com)
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Firebase Messaging Sender ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id

# Firebase App ID
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Optional: Firebase Measurement ID (for Google Analytics)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Admin Secret for protected API endpoints (device auth, backfill operations)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=your-admin-secret-here

# Resend Email Service (for device authentication emails)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Musa Security <noreply@musa-security.com>

# Flutterwave Configuration
FLUTTERWAVE_SECRET_KEY=FLWSECK-...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-...
FLUTTERWAVE_ENCRYPTION_KEY=...

# Flutterwave Proxy (for IP whitelisting)
FLW_PROXY_URL=https://your-proxy-url.com
FLW_PROXY_SECRET=your-proxy-secret-here
